=>-> just means char*[], a slice of pointers to u8
*/
i8 fn main: =>->u8 args { 
    if(args.len == 0) {
        print("no input")
    }
    if(args[1] == "help"){
        print("usage: args <command>")
    }

    //simple calculator

    if(args[1] == "sum"){
        ->u8 arg2 = args[2]
        ->u8 arg3 = args[3]


    }
}